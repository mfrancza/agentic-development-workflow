repo_owner           = "your-github-username"
repo_name            = "agentic-development-workflow"
# Include the agent bot identities (e.g. the developer agent) so agents can
# apply agent:* labels (like `agent:review`) and trigger other agents. The
# `[bot]` suffix matches `github.event.sender.login` for GitHub App events.
agent_allowlist = [
  "your-github-username",
  "mfrancza-developer-agent[bot]",
  "mfrancza-reviewer-agent[bot]",
]
default_claude_model = "sonnet"
